@model OperationResultViewModel?

@if (Model is not null)
{
    <section class="result-panel @(Model.IsSuccess ? "result-success" : "result-error") mt-4">
        <div class="d-flex flex-column flex-md-row justify-content-between gap-2 align-items-start">
            <div>
                <p class="eyebrow mb-1">Operation result</p>
                <h2 class="h5 mb-1">@(Model.IsSuccess ? "Success" : "Request failed")</h2>
                <p class="mb-0">@Model.Message</p>
            </div>
            @if (!string.IsNullOrWhiteSpace(Model.ErrorCode))
            {
                <span class="badge text-bg-dark">@Model.ErrorCode</span>
            }
        </div>

        @if (Model.IsSuccess)
        {
            <div class="mt-3">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <h3 class="h6 mb-0">Document payload</h3>
                    <button class="btn btn-sm btn-outline-light" type="button" data-copy-json data-target="#operation-json">Copy JSON</button>
                </div>
                <pre id="operation-json" class="json-view" data-json-block>@Model.JsonPayload</pre>
            </div>
            <details class="mt-3">
                <summary>Raw response</summary>
                <pre class="json-view mt-2">@Model.RawResponseJson</pre>
            </details>
        }
        else
        {
            <div class="mt-3">
                <p class="mb-1"><strong>Error message:</strong> @Model.ErrorMessage</p>
                <details>
                    <summary>Raw response</summary>
                    <pre class="json-view mt-2">@Model.RawResponseJson</pre>
                </details>
            </div>
        }
    </section>
}
