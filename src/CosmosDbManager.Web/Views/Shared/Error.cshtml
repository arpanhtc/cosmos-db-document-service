@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<section class="page-simple">
    <p class="eyebrow">Unexpected error</p>
    <h1 class="text-danger">Something went wrong</h1>
    <p class="lead">The application caught an unexpected exception and redirected you here instead of showing a stack trace.</p>

    @if (Model.ShowRequestId)
    {
        <p class="mb-2">
            <strong>Request ID:</strong> <code>@Model.RequestId</code>
        </p>
    }

    <div class="d-flex flex-wrap gap-2">
        <a class="btn btn-primary" asp-controller="Home" asp-action="Index">Back Home</a>
        <a class="btn btn-outline-secondary" asp-controller="Document" asp-action="Insert">Try Insert</a>
    </div>
</section>
