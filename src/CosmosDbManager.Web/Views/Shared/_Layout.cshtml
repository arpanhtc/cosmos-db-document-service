<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Cosmos Db Manager</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/CosmosDbManager.Web.styles.css" asp-append-version="true" />
</head>
<body>
    <header class="site-header">
        <nav class="navbar navbar-expand-lg navbar-dark site-nav">
            <div class="container-fluid px-3 px-lg-4">
                <a class="navbar-brand fw-semibold tracking-wide" asp-controller="Home" asp-action="Index">Cosmos Db Manager</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav ms-auto gap-lg-1">
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">Home</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Configuration" asp-action="Index">Configuration</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Document" asp-action="Insert">Insert</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Document" asp-action="Upsert">Upsert</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Document" asp-action="Get">Get</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Document" asp-action="Patch">Patch</a></li>
                        <li class="nav-item"><a class="nav-link" href="/swagger">Swagger</a></li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main class="app-shell container-fluid px-3 px-lg-4 py-4">
        @if (TempData["StatusMessage"] is string statusMessage)
        {
            <div class="alert alert-success shadow-sm border-0 mb-4" role="alert">
                @statusMessage
            </div>
        }

        <div class="content-frame">
            @RenderBody()
        </div>
    </main>

    <footer class="site-footer">
        <div class="container-fluid px-3 px-lg-4 py-3 d-flex flex-column flex-md-row justify-content-between gap-2">
            <span>&copy; 2026 - Cosmos Db Manager</span>
            <span class="text-muted">MVC UI, REST API, Swagger, and session-backed configuration</span>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/json-formatter.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
